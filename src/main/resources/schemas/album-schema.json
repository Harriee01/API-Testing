{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Album",
    "description": "JSON Schema for a single /albums resource from JSONPlaceholder",
    "type": "object",
    "required": [
        "userId",
        "id",
        "title"
    ],
    "properties": {
        "userId": {
            "type": "integer",
            "minimum": 1,
            "description": "The id of the user who owns this album"
        },
        "id": {
            "type": "integer",
            "minimum": 1,
            "description": "Server-assigned unique album id"
        },
        "title": {
            "type": "string",
            "minLength": 1,
            "description": "Title / name of the album"
        }
    },
    "additionalProperties": false
}