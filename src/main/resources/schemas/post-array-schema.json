{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "PostArray",
    "description": "JSON Schema for an array of JSONPlaceholder post resources",
    "type": "array",
    "minItems": 1,
    "items": {
        "type": "object",
        "required": [
            "userId",
            "id",
            "title",
            "body"
        ],
        "additionalProperties": false,
        "properties": {
            "userId": {
                "type": "integer",
                "minimum": 1
            },
            "id": {
                "type": "integer",
                "minimum": 1
            },
            "title": {
                "type": "string"
            },
            "body": {
                "type": "string"
            }
        }
    }
}