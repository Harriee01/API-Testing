{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Todo",
    "description": "JSON Schema for a single /todos resource from JSONPlaceholder",
    "type": "object",
    "required": [
        "userId",
        "id",
        "title",
        "completed"
    ],
    "properties": {
        "userId": {
            "type": "integer",
            "minimum": 1,
            "description": "The id of the user this todo belongs to"
        },
        "id": {
            "type": "integer",
            "minimum": 1,
            "description": "Server-assigned unique todo id"
        },
        "title": {
            "type": "string",
            "minLength": 1,
            "description": "Title / description of the todo item"
        },
        "completed": {
            "type": "boolean",
            "description": "Whether the todo has been completed"
        }
    },
    "additionalProperties": false
}