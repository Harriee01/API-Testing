# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — JSONPlaceholder REST Assured Automation Framework
# ──────────────────────────────────────────────────────────────────────────────

# ── Maven build output ────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── Allure results & report (generated at runtime, never committed) ───────────
allure-results/
allure-report/

# ── IntelliJ IDEA ─────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
# Keep shared run configurations if you use them
!.idea/runConfigurations/

# ── Eclipse ───────────────────────────────────────────────────────────────────
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ── NetBeans ──────────────────────────────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── Operating system artefacts ────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows
Thumbs.db
ehthumbs.db
desktop.ini
# Linux
*~

# ── Environment & secrets (NEVER commit credentials) ─────────────────────────
.env
.env.*
*.properties.local
secrets/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Java compiled classes (outside target/) ──────────────────────────────────
*.class

# ── JAR / WAR / EAR / ZIP build artefacts ────────────────────────────────────
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
# Keep the Maven wrapper JAR
!.mvn/wrapper/maven-wrapper.jar